#!/usr/bin/env bash
set -e

lock() {
    bwbio lock
}

trap lock EXIT

BW_SESSION="$(bwbio unlock --raw)"
export BW_SESSION

chezmoi apply --dry-run --verbose

read -p "Are you sure? " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    find "$HOME/.local/bin" -maxdepth 1 -type f -name ",*" -exec rm {} +
    chezmoi apply --force

    cd "$HOME"/.config/fnox
    fnox sync -g -p age -f
fi
